# Copy this file to .env and fill in your values
# Never commit .env to version control

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@your-host:5432/your-database

# Session secret - use a long, random string (e.g. openssl rand -hex 64)
SESSION_SECRET=replace-this-with-a-long-random-secret-string

# Server port (optional, defaults to 3000)
PORT=3000

# Environment (development | production)
# In production, cookies are sent only over HTTPS
NODE_ENV=development

# Password pepper - a secret string concatenated with the password before hashing.
# Generate a unique value with: node -p "require('crypto').randomBytes(32).toString('hex')"
# NEVER change this after users have registered — it will invalidate all passwords.
PASSWORD_PEPPER=replace-this-with-a-long-random-hex-string
